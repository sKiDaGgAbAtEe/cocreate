# ── HIVE Environment Variables ──────────────────────────────────────────────

# Anthropic — required for S.A.R.A. and triune reads
ANTHROPIC_API_KEY=your_anthropic_key_here

# Daily.co — required for voice channels
DAILY_API_KEY=your_daily_api_key_here
DAILY_DOMAIN=your-domain.daily.co

# Server
PORT=3000
SESSION_SECRET=change_me_in_production

# Optional: RCO integration (if connecting to Clio/Orycl stack)
# RCO_HTTP_URL=http://localhost:5051
# RCO_WS_URL=ws://localhost:5050/field
